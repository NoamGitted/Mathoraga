<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F2000000"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/txtlobbyID"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lobby ID: ---- | Rounds Left: --"
        android:textColor="#BBFFFFFF"
        android:textSize="14sp"
        android:letterSpacing="0.1" />

    <TextView
        android:id="@+id/txt_leaderboard_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LEADERBOARD"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_leaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="vertical" />

    <Button
        android:id="@+id/btn_next_round"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#4CAF50"
        android:text="START NEXT ROUND"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="4dp"/>

    <Button
        android:id="@+id/btn_end"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FF2400"
        android:text="END GAME"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="4dp"/>

</LinearLayout>