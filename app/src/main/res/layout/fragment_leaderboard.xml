<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#E6000000"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/txtlobbyID"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lobby ID"
        android:textColor="#FFFFFF"
        />
    <TextView
        android:id="@+id/txt_leaderboard_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LEADERBOARD"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_leaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <Button
        android:id="@+id/btn_next_round"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#4CAF50"
        android:text="START NEXT ROUND"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:visibility="gone" />
    <Button
        android:id="@+id/btn_end"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#FF2400"
        android:text="END GAME"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:visibility="gone"/>

</LinearLayout>